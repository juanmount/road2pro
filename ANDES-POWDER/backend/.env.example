NODE_ENV=development
PORT=3000

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/andes_powder

# Open-Meteo API (no key required, but rate limits apply)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Cron schedule (every 3 hours)
FORECAST_CRON_SCHEDULE=0 */3 * * *

# Firebase Admin SDK
# Option 1: Use service account file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Use environment variables
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudinary (for profile photo uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Feature Flags (Weather Intelligence Improvements)
# USE_FORECAST_HISTORY: Enable forecast run history trend analysis
# USE_T850: Enable Temperature 850 hPa for better phase classification
USE_FORECAST_HISTORY=false
USE_T850=false
