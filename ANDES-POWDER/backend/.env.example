NODE_ENV=development
PORT=3000

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/andes_powder

# Open-Meteo API (no key required, but rate limits apply)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Cron schedule (every 3 hours)
FORECAST_CRON_SCHEDULE=0 */3 * * *

# Firebase Admin SDK
# Option 1: Use service account file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option 2: Use environment variables
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
