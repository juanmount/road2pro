      "ios": { "image": "macos-sequoia-15.3-xcode-16.2" }
    },
    "apk": {
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "production": {
      "autoIncrement": true,
      "developmentClient": false,
      "distribution": "store",
      "ios": { "image": "macos-sequoia-15.3-xcode-16.2" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6755497113"
      }
    }
  }
}
